<?xml version="1.0"?>
<robot name="combat_bot">
  <!-- Chassis: 150mm x 150mm x 30mm box -->
  <link name="chassis">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.15 0.15 0.03"/>
      </geometry>
      <material name="chassis_color">
        <color rgba="0.8 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.15 0.15 0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Left wheel (at y=-0.075, left side) -->
  <link name="left_wheel">
    <contact>
      <lateral_friction value="1.0"/>
      <rolling_friction value="0.01"/>
      <spinning_friction value="0.001"/>
    </contact>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.03"/>
      </geometry>
      <material name="wheel_color">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Right wheel (at y=+0.075, right side) -->
  <link name="right_wheel">
    <contact>
      <lateral_friction value="1.0"/>
      <rolling_friction value="0.01"/>
      <spinning_friction value="0.001"/>
    </contact>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.03"/>
      </geometry>
      <material name="wheel_color">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Front caster -->
  <link name="front_caster">
    <contact>
      <lateral_friction value="0.3"/>
      <rolling_friction value="0.01"/>
    </contact>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="caster_color">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
  </link>

  <!-- Back caster -->
  <link name="back_caster">
    <contact>
      <lateral_friction value="0.3"/>
      <rolling_friction value="0.01"/>
    </contact>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="caster_color">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
  </link>

  <!-- Joints -->
  <!-- rpy="1.5708 0 0" rotates the wheel 90 deg around X, making it horizontal -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="left_wheel"/>
    <origin rpy="1.5708 0 0" xyz="0 -0.075 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="right_wheel"/>
    <origin rpy="1.5708 0 0" xyz="0 0.075 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="front_caster_joint" type="fixed">
    <parent link="chassis"/>
    <child link="front_caster"/>
    <origin rpy="0 0 0" xyz="0.05 0 -0.015"/>
  </joint>

  <joint name="back_caster_joint" type="fixed">
    <parent link="chassis"/>
    <child link="back_caster"/>
    <origin rpy="0 0 0" xyz="-0.05 0 -0.015"/>
  </joint>
</robot>
